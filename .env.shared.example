# ============================================
# 影视模版 - 前后端共享配置
# 此文件包含前后端共用的配置项
# ============================================

# 请求签名密钥 - 前后端必须完全一致(16位随机字符串)
NUXT_PUBLIC_AUTHOR_KEY=your_author_key_here

# API 基础地址配置
# 生产环境：留空表示使用同域（通过 nginx 代理到后端 8000，避免跨域）
# 开发环境：DEBUG_API_BASE 用于本地开发
NUXT_PUBLIC_API_BASE=
NUXT_PUBLIC_DEBUG_API_BASE=your_debug_api_base_here

# CORS 配置 - 允许跨域访问的域名
# 开发环境: localhost + 3333端口
# 生产环境: HTTP(80端口) + HTTPS(81端口)
# 注意: HTTPS 和 HTTP 是不同协议，需要分别配置
ALLOW_ORIGINS_DEV=http://localhost:3333,http://127.0.0.1:3333
ALLOW_ORIGINS_PROD=http://localhost:3000,http://127.0.0.1:3000

# 联系邮箱
NUXT_PUBLIC_CONTACT_EMAIL=your_contact_email_here

# 备案号（显示在页面底部）
NUXT_PUBLIC_ICP_NUMBER=your_icp_number_here

# 短信服务测试验证码（非测试逻辑，用于开发/内部环境绕过阿里云验证）
# 设置后，用户输入此验证码可直接通过验证（不调用阿里云接口）
# 生产环境请留空以禁用此功能
SMS_TEST_CODE=your_sms_test_code_here