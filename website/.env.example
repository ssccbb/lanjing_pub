# 前端私有配置
# 共享配置请修改项目根目录的 .env.shared 文件

# ============================================
# 应用品牌配置
# ============================================

# 应用名称
NUXT_PUBLIC_APP_NAME=影视模版

# 应用标语
NUXT_PUBLIC_APP_SLOGAN=影视模版Slogan

# 应用副标语
NUXT_PUBLIC_APP_SUB_SLOGAN=影视模版SloganSub

# ============================================
# 协议页面配置
# ============================================

# 用户协议URL
NUXT_PUBLIC_POLICY_AGREEMENT=your_user_agreement_url
# 隐私政策URL
NUXT_PUBLIC_POLICY_PRIVACY=your_user_privacy_url
